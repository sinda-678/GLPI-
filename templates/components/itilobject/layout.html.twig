{% set rand = random() %}
{% set main_rand = rand %}
{% set is_helpdesk = get_current_interface() == 'helpdesk' %}
{% set show_extra_fields = not is_helpdesk or show_tickets_properties_on_helpdesk %}

{% set itil_layout = user_pref('itil_layout', true) %}
{% set is_collapsed = (itil_layout['collapsed'] ?? false) == "true" %}
{% set is_expanded  = (itil_layout['expanded'] ?? false) == "true" %}
{% set collapsed_cls = (is_collapsed ? "right-collapsed" : "") %}
{% set expanded_cls  = (is_expanded == "true" ? "right-expanded" : "") %}
{% set template_preview = params.template_preview|default(false) %}

{% set left_regular_cls = "col-lg-8" %}
{% set right_regular_cls = "col-lg-4" %}

{% set left_expanded_cls = "col-xl-5 col-lg-6" %}
{% set right_expanded_cls = "col-xl-7 col-lg-6" %}

{% set left_side_cls = left_regular_cls %}
{% set right_side_cls = right_regular_cls %}
{% if is_expanded %}
    {% set left_side_cls = left_expanded_cls %}
    {% set right_side_cls = right_expanded_cls %}
{% endif %}


<div id="itil-object-container" class="mt-n1 {{ collapsed_cls }} {{ expanded_cls }}">

   {% if item.isNewItem() and not template_preview %}
      {{ include('components/itilobject/mainform_open.html.twig') }}
   {% endif %}

   <div class="row d-flex flex-column itil-object">
      {% set is_timeline_reversed = user_pref('timeline_order') == constant('CommonITILObject::TIMELINE_ORDER_REVERSE') %}
      {% set fl_direction = (item.isNewItem() or is_timeline_reversed ? 'flex-column' : 'flex-column-reverse') %}
      <div class="itil-left-side col-12 {{ left_side_cls }} order-last order-lg-first pt-2 pe-2 pe-lg-4 d-flex {{ fl_direction }} border-top border-4 {{ not show_extra_fields ? "w-100" : "" }}">
         {% if item.isNewItem() %}
            {{ include('components/itilobject/timeline/new_form.html.twig') }}
         {% else %}
            {{ include('components/itilobject/timeline/timeline.html.twig') }}
         {% endif %}
      </div>
      {% if show_extra_fields %}
         <div class="itil-right-side col-12 {{ right_side_cls }} mt-0 mt-lg-n1 card-footer p-0 rounded-0">
            {% if not item.isNewItem() %}
               {{ include('components/itilobject/mainform_open.html.twig') }}
            {% endif %}
            {{ include('components/itilobject/fields_panel.html.twig') }}
            {% if not item.isNewItem() %}
               {{ include('components/itilobject/mainform_close.html.twig') }}
            {% endif %}
         </div>
      {% endif %}
   </div>

   {% if not template_preview %}
      {{ include('components/itilobject/footer.html.twig') }}
      {% if not item.isNewItem() %}
           {{ include('components/itilobject/mainform_close.html.twig') }}
      {% endif %}
   {% endif %}
</div>

{# Common form fields for CommonITILObject_CommonITILObject purge action #}
<form method="POST" action="{{ call('CommonITILObject_CommonITILObject::getFormURL') }}" class="d-none" id="linked_itilobjects_{{ main_rand }}" data-submit-once>
   <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}" />
   <input type="hidden" name="purge" value="1" />
   <input type="hidden" name="itemtype" value="{{ item.getType() }}" />
   <input type="hidden" name="items_id" value="{{ item.fields['id'] }}" />
</form>

{# Common form fields for "addme_as_actor" action #}
{% for actortype in ['requester', 'observer', 'assign'] %}
   <form method="POST" action="{{ item.getFormURL() }}" class="d-none" id="addme_as_{{ actortype }}_{{ main_rand }}" data-submit-once>
      <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}" />
      <input type="hidden" name="addme_as_actor" value="1" />
      <input type="hidden" name="actortype" value="{{ actortype }}" />
   </form>
{% endfor %}

<form name="massaction_{{ rand }}" id="massaction_{{ rand }}" method="post"
      action="{{ path('/front/massiveaction.php') }}?_single_item[itemtype]={{ item.getType() }}&_single_item[id]={{ item.getID() }}" data-submit-once>
   <div id="massive_container_{{ rand }}"></div>
   <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}" />
</form>

<script type="text/javascript">
$(function() {
   $(document).on("click", ".switch-panel-width", function() {
       if ($('#itil-object-container').hasClass('right-collapsed')) {
           $('#itil-object-container').removeClass('right-collapsed');
       } else if ($('.itil-left-side').hasClass("{{ left_regular_cls }}")) {
         // Expand right-side panel
         $('#itil-object-container').addClass('right-expanded');
         // Left side
         $('.itil-left-side').removeClass("{{ left_regular_cls }}").addClass("{{ left_expanded_cls }}");
         $('.itil-footer .timeline-buttons').removeClass("{{ left_regular_cls }}").addClass("{{ left_expanded_cls }}");
         // Right side
         $('.itil-footer .form-buttons').removeClass('col-lg').addClass("{{ right_expanded_cls }}");
         $('.itil-right-side').removeClass("{{ right_regular_cls }}").addClass("{{ right_expanded_cls }}");
         // Switcher buttons
         $('.switch-panel-width i.fas').removeClass('fa-caret-left').addClass('fa-caret-right');
         $('.itil-right-side .accordion-body:not(.accordion-actors).row .col-12').removeClass('col-12').addClass('col-sm-6');
         $('#actors .col-12').removeClass('col-12').addClass('col-sm-4');
      } else {
         // Decrease right-side panel
         $('#itil-object-container').removeClass('right-expanded');
         // Left side
         $('.itil-left-side').removeClass("{{ left_expanded_cls }}").addClass("{{ left_regular_cls }}");
         $('.itil-footer .timeline-buttons').removeClass("{{ left_expanded_cls }}").addClass("{{ left_regular_cls }}");
         // Right side
         $('.itil-footer .form-buttons').removeClass("{{ right_expanded_cls }}").addClass('col-lg');
         $('.itil-right-side').removeClass("{{ right_expanded_cls }}").addClass("{{ right_regular_cls }}");
         // Switcher buttons
         $('.switch-panel-width i.fas').removeClass('fa-caret-right').addClass('fa-caret-left');
         $('.itil-right-side .accordion-body:not(.accordion-actors).row .col-sm-6').removeClass('col-sm-6').addClass('col-12');
         $('#actors .col-sm-4').removeClass('col-sm-4').addClass('col-12');
      }

      saveFieldPanelState();
   });

    $(document).on("click", ".collapse-panel", function() {
       $('#itil-object-container').addClass('right-collapsed');

        // Hide all accordion item
        $('#itil-data .accordion-collapse').removeClass('show');
        $('#itil-data .accordion-button').addClass('collapsed');

       saveFieldPanelState();
    });

    $(document).on("click", ".right-collapsed .itil-right-side", function(event) {
        $('#itil-object-container').removeClass('right-collapsed');
        saveFieldPanelState();
    });

    var myCollapsible = document.getElementById('itil-data')
    myCollapsible.addEventListener('shown.bs.collapse', function () {
        saveFieldPanelState();
    });
    myCollapsible.addEventListener('hidden.bs.collapse', function () {
        saveFieldPanelState();
    });

    var itil_layout = {
        collapsed: false,
        expanded: false,
        items: {}
    };

    var saveFieldPanelState = function() {
        itil_layout.collapsed = $('#itil-object-container').hasClass('right-collapsed');
        itil_layout.expanded  = $('#itil-object-container').hasClass('right-expanded');

        $('#itil-data .accordion-collapse').each(function() {
            var item_shown = $(this).hasClass('show');
            var item_id    = $(this).attr('id');

            itil_layout.items[item_id] = item_shown;
        });

        $.ajax({
            url: CFG_GLPI.root_doc + '/ajax/itillayout.php',
            type: 'POST',
            datatype: "json",
            data: {
                'itil_layout': itil_layout
            }
        });
    }

    var restoreFieldPanelState = function() {
        $.each(field_panel_state.items, function(item_id, item_shown) {
            if (item_shown) {
                $('#' + item_id).addClass('show');
            } else {
                $('#' + item_id).removeClass('show');
            }
        });
    }
});
</script>

{% if not item.isNewItem() %}
{#
 # =========================================================================
 # AUTO-REFRESH — Ticket Conversation Page
 # =========================================================================
 #
 # Automatically reloads the ticket page every 30 seconds to ensure users
 # always see the latest activity (replies, status changes, assignments,
 # solutions, etc.) without manually refreshing.
 #
 # Smart behavior:
 #   - Pauses when the browser tab is hidden (Page Visibility API)
 #   - Postpones if the user is typing in an editor/input
 #   - Postpones if a file upload is in progress
 #   - Postpones if a form is being submitted
 #   - Postpones if a modal dialog is open
 #   - Shows a 5-second countdown banner with "Refresh Now" / "Postpone"
 #
 # Single timer, no memory leaks, cleaned up on page unload.
 # =========================================================================
 #}
<script type="text/javascript">
(function() {
    // ── Configuration ──────────────────────────────────────────────────
    var REFRESH_INTERVAL = 30;   // seconds between refresh cycles
    var WARNING_SECONDS  = 5;    // seconds before refresh to show banner
    var BANNER_ID        = 'glpi-auto-refresh-banner';

    // ── State ──────────────────────────────────────────────────────────
    var _secondsLeft    = REFRESH_INTERVAL;
    var _timer          = null;
    var _paused         = false;
    var _initialValues  = {};    // stores initial editor content for change detection

    // ── Safety checks ──────────────────────────────────────────────────

    /**
     * Detect if any editor/textarea/text input contains unsaved text
     * that differs from when the page loaded.
     */
    function hasUnsavedText() {
        // TinyMCE editors
        if (typeof tinymce !== 'undefined') {
            var editors = tinymce.get();
            for (var i = 0; i < editors.length; i++) {
                var id = editors[i].id;
                var content = editors[i].getContent();
                if (_initialValues['mce_' + id] === undefined) {
                    _initialValues['mce_' + id] = content;
                }
                if (content !== '' && content !== _initialValues['mce_' + id]) {
                    return true;
                }
            }
        }

        // Plain textareas
        var textareas = document.querySelectorAll('#itil-footer textarea, #itil-object-container textarea');
        for (var i = 0; i < textareas.length; i++) {
            var ta = textareas[i];
            var key = 'ta_' + (ta.id || i);
            if (_initialValues[key] === undefined) {
                _initialValues[key] = ta.value;
            }
            if (ta.value !== '' && ta.value !== _initialValues[key]) {
                return true;
            }
        }

        // Text inputs (excluding hidden, submit, button, checkbox, radio)
        var inputs = document.querySelectorAll('#itil-footer input[type="text"], #itil-object-container input[type="text"]');
        for (var i = 0; i < inputs.length; i++) {
            var inp = inputs[i];
            var key = 'inp_' + (inp.name || inp.id || i);
            if (_initialValues[key] === undefined) {
                _initialValues[key] = inp.value;
            }
            if (inp.value !== '' && inp.value !== _initialValues[key]) {
                return true;
            }
        }

        return false;
    }

    /**
     * Detect if a textarea, input, or contenteditable element is focused.
     */
    function hasFocusedInput() {
        var el = document.activeElement;
        if (!el || el === document.body) return false;
        var tag = el.tagName.toLowerCase();
        if (tag === 'textarea') return true;
        if (tag === 'input' && el.type !== 'hidden' && el.type !== 'submit' && el.type !== 'button') return true;
        if (el.getAttribute('contenteditable') === 'true') return true;
        // Check if focus is inside a TinyMCE editor
        if (typeof tinymce !== 'undefined' && tinymce.activeElement) return true;
        return false;
    }

    /**
     * Detect if a file upload is in progress.
     */
    function hasFileUpload() {
        // Check file inputs with files selected
        var fileInputs = document.querySelectorAll('#itil-footer input[type="file"], #itil-object-container input[type="file"]');
        for (var i = 0; i < fileInputs.length; i++) {
            if (fileInputs[i].files && fileInputs[i].files.length > 0) {
                return true;
            }
        }
        // Check for active upload indicators (GLPI upload progress bar)
        if (document.querySelector('.fileupload, .upload-progress, .glpi-upload-progress')) {
            return true;
        }
        return false;
    }

    /**
     * Detect if a form is currently being submitted.
     */
    function hasFormSubmit() {
        var forms = document.querySelectorAll('#itil-footer form, #itil-object-container form, #itil-form');
        for (var i = 0; i < forms.length; i++) {
            if (forms[i].getAttribute('data-submitting') === 'true') {
                return true;
            }
        }
        return false;
    }

    /**
     * Detect if a Bootstrap modal dialog is currently open.
     */
    function hasOpenModal() {
        var modals = document.querySelectorAll('.modal.show, .modal[style*="display: block"]');
        return modals.length > 0;
    }

    /**
     * Master safety check: returns true if ANY unsafe condition is met.
     */
    function isUnsafe() {
        return hasUnsavedText() || hasFocusedInput() || hasFileUpload() || hasFormSubmit() || hasOpenModal();
    }

    // ── Banner ─────────────────────────────────────────────────────────

    function showBanner() {
        if (document.getElementById(BANNER_ID)) return;

        var banner = document.createElement('div');
        banner.id = BANNER_ID;
        banner.setAttribute('role', 'alert');
        banner.style.cssText = [
            'position:fixed',
            'top:0',
            'left:0',
            'right:0',
            'z-index:99999',
            'background:#0d6efd',
            'color:#fff',
            'padding:8px 16px',
            'font-size:14px',
            'font-family:inherit',
            'display:flex',
            'align-items:center',
            'justify-content:center',
            'gap:12px',
            'box-shadow:0 2px 8px rgba(0,0,0,0.2)'
        ].join(';');

        var msg = document.createElement('span');
        msg.id = BANNER_ID + '-text';
        msg.textContent = 'Cette page sera actualisée dans ' + _secondsLeft + ' seconde(s) pour charger les dernières mises à jour du ticket.';
        banner.appendChild(msg);

        var btnRefresh = document.createElement('button');
        btnRefresh.textContent = 'Actualiser maintenant';
        btnRefresh.style.cssText = 'background:#fff;color:#0d6efd;border:none;padding:4px 12px;border-radius:4px;cursor:pointer;font-weight:bold;font-size:13px;white-space:nowrap;';
        btnRefresh.onclick = function() { window.location.reload(); };
        banner.appendChild(btnRefresh);

        var btnPostpone = document.createElement('button');
        btnPostpone.textContent = 'Reporter';
        btnPostpone.style.cssText = 'background:transparent;color:#fff;border:1px solid #fff;padding:4px 12px;border-radius:4px;cursor:pointer;font-size:13px;white-space:nowrap;';
        btnPostpone.onclick = function() { postpone(); };
        banner.appendChild(btnPostpone);

        document.body.appendChild(banner);
    }

    function updateBannerText() {
        var textEl = document.getElementById(BANNER_ID + '-text');
        if (textEl) {
            textEl.textContent = 'Cette page sera actualisée dans ' + _secondsLeft + ' seconde(s) pour charger les dernières mises à jour du ticket.';
        }
    }

    function removeBanner() {
        var banner = document.getElementById(BANNER_ID);
        if (banner) {
            banner.parentNode.removeChild(banner);
        }
    }

    // ── Timer control ──────────────────────────────────────────────────

    function postpone() {
        _secondsLeft = REFRESH_INTERVAL;
        removeBanner();
        if (typeof glpi_toast_info === 'function') {
            glpi_toast_info('Actualisation reportée', 'Prochaine vérification dans ' + REFRESH_INTERVAL + ' secondes.', { delay: 3000 });
        }
    }

    function tick() {
        if (_paused) return;

        _secondsLeft--;

        if (_secondsLeft <= WARNING_SECONDS && _secondsLeft > 0) {
            showBanner();
            updateBannerText();
        }

        if (_secondsLeft <= 0) {
            removeBanner();

            if (isUnsafe()) {
                postpone();
                return;
            }

            window.location.reload();
        }
    }

    function startTimer() {
        stopTimer();
        _secondsLeft = REFRESH_INTERVAL;
        _timer = setInterval(tick, 1000);
    }

    function stopTimer() {
        if (_timer) {
            clearInterval(_timer);
            _timer = null;
        }
    }

    // ── Event listeners ────────────────────────────────────────────────

    // Pause when tab is hidden, resume when visible
    document.addEventListener('visibilitychange', function() {
        if (document.hidden) {
            _paused = true;
            removeBanner();
        } else {
            _paused = false;
            _secondsLeft = REFRESH_INTERVAL;
        }
    });

    // Cleanup on page unload
    window.addEventListener('beforeunload', function() {
        stopTimer();
        removeBanner();
    });

    // ── Initialize ─────────────────────────────────────────────────────
    startTimer();
})();
</script>
{% endif %}
